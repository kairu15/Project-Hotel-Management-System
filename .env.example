# Bayawan Bai Hotel - Environment Configuration
# Copy this file to .env and fill in your actual values

# Database configuration
DB_HOST=localhost
DB_NAME=bayawan_hotel
DB_USER=root
DB_PASS=

# Site configuration
SITE_NAME="Bayawan Bai Hotel"
SITE_URL=http://localhost/bayawanhotel
ADMIN_EMAIL=bayawanbaiminihotel@gmail.com

# Email configuration for OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=bayawanbaiminihotel@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=bayawanbaiminihotel@gmail.com
SMTP_FROM_NAME="Bayawan Bai Hotel"

# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Langbly Translation API Configuration
LANGBLY_API_KEY=your_langbly_api_key_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost/bayawanhotel/auth/google-callback.php

# Facebook OAuth Configuration
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_REDIRECT_URI=http://localhost/bayawanhotel/auth/facebook-callback.php
