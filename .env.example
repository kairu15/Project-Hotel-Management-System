# Bayawan Bai Hotel - Environment Configuration Template
# Copy this file to .env and fill in your actual API keys
# NEVER commit the .env file to version control!

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=bayawan_hotel

# Google Gemini API Configuration
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Configuration
# Get your free API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Langbly Translation API Configuration
# Free tier: ~500,000 characters/month
# Get your free API key from: https://langbly.com
LANGBLY_API_KEY=your_langbly_api_key_here

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost/bayawanhotel/auth/google-callback.php

# Facebook OAuth Configuration
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_REDIRECT_URI=http://localhost/bayawanhotel/auth/facebook-callback.php

# SMTP Configuration (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email_here
SMTP_PASS=your_smtp_password_here
SMTP_FROM=your_smtp_email_here
SMTP_FROM_NAME="Bayawan Bai Hotel"
